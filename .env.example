# ============================================================
# ShipRocket AI Employee Platform — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# The platform runs in MOCK MODE by default when API keys
# are not provided — no external services required.
# ============================================================

# ── Core ─────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key

# ── Database (SQLite — no external DB needed) ────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/shiprocket.db

# ── OpenAI ───────────────────────────────────────────────────
# Required for AI chat. Leave empty to use mock responses.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Shopify Connector ───────────────────────────────────────
# Leave empty to use mock Shopify data.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_STORE_DOMAIN=

# ── Meta Ads Connector ──────────────────────────────────────
# Leave empty to use mock Meta Ads data.
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_APP_SECRET=

# ── Google Sheets Connector ─────────────────────────────────
# Leave empty to use mock Google Sheets data.
GOOGLE_SHEETS_CREDENTIALS_FILE=
GOOGLE_SHEETS_SPREADSHEET_ID=

# ── Agent Configuration ─────────────────────────────────────
AGENT_SCHEDULE_HOURS=6
AD_SPEND_ROAS_THRESHOLD=2.0
AD_SPEND_MIN_SPEND=1000
